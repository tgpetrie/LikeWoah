{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "videoedit",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; p=int(os.environ.get('PORT',8000)); socketserver.TCPServer(('',p),http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "autoPort": true
    }
  ]
}
